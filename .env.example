# --- Eve chat (real model) ---
# Preferred: Anthropic Claude. If set, Eve chats with Claude.
ANTHROPIC_API_KEY=
# Optional model override for Eve chat (default: claude-opus-4-8).
EVE_ANTHROPIC_MODEL=

# Fallback chat provider + required for real AI plant identification/diagnosis
# in Photo Journal.
OPENAI_API_KEY=
# Optional. Override the vision model if your OpenAI project uses a different one.
OPENAI_VISION_MODEL=gpt-5.5
# Optional. Chat model when Eve falls back to OpenAI.
OPENAI_CHAT_MODEL=

# --- Greenhouse sensor (Govee thermometer/hygrometer) ---
# Get a key in the Govee Home app: Profile -> Settings (gear) -> Apply for API Key.
GOVEE_API_KEY=
# Optional: pin a specific device if auto-detect picks the wrong one.
# Find values at /api/govee/devices after setting the API key.
GOVEE_DEVICE=
GOVEE_SKU=

# --- Hermes/Eve knowledge source (optional) ---
# If Hermes/Eve exposes a context endpoint, the app will call it first
# and pass that knowledge into the OpenAI vision diagnosis prompt.
HERMES_EVE_CONTEXT_URL=
HERMES_EVE_API_KEY=
